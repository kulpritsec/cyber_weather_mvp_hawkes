# Database (SQLite for dev, PostgreSQL for production)
CYBER_WEATHER_DATABASE_URL=sqlite:///./cyber_weather.db
# CYBER_WEATHER_DATABASE_URL=postgresql://cyberweather:changeme@localhost:5432/cyber_weather

# Environment
CYBER_WEATHER_ENV=development

# Grid
CYBER_WEATHER_GRID_RESOLUTION_DEG=2.5

# Hawkes model
CYBER_WEATHER_HAWKES_MIN_EVENTS=50
CYBER_WEATHER_HAWKES_BOOTSTRAP_SAMPLES=20

# Vectors (comma-separated if overriding via env)
# CYBER_WEATHER_DEFAULT_VECTORS=["ssh","rdp","http","dns_amp","ransomware"]

# CORS (comma-separated for production)
# CYBER_WEATHER_CORS_ORIGINS=https://cyberweather.example.com

# Server
CYBER_WEATHER_SERVER_HOST=0.0.0.0
CYBER_WEATHER_SERVER_PORT=8000
CYBER_WEATHER_SERVER_RELOAD=true
